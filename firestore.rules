rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isUserAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isUserAdmin());
      allow list: if isSignedIn() && isUserAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isUserAdmin()) && (request.auth.uid != userId || request.resource.data.role == resource.data.role);
      allow delete: if isSignedIn() && isUserAdmin();
      
      // Wishlist Subcollection
      match /wishlist/{productId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Doctors Collection
    match /doctors/{doctorId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == doctorId || isUserAdmin());
    }

    // Appointments Collection
    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.doctorId == request.auth.uid || isUserAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.doctorId == request.auth.uid || isUserAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.doctorId == request.auth.uid || isUserAdmin());
      allow delete: if isSignedIn() && isUserAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isUserAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isUserAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isUserAdmin();
      allow delete: if isSignedIn() && isUserAdmin();
    }
  }
}
