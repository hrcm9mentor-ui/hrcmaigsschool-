{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with role simulation and cosmological calibration parameters.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user identity" },
        "email": { "type": "string", "description": "Registered email" },
        "displayName": { "type": "string", "description": "Seeker name" },
        "phone": { "type": "string", "description": "Phone number" },
        "role": { "type": "string", "enum": ["user", "doctor", "student", "admin"] },
        "createdAt": { "type": "string" },
        "birthDate": { "type": "string" },
        "birthTime": { "type": "string" },
        "birthPlace": { "type": "string" },
        "vastuPreferences": { "type": "string" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt"]
    },
    "DoctorProfile": {
      "title": "DoctorProfile",
      "description": "Verified doctor profile with expertise, availability, and rating.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "degree": { "type": "string" },
        "specialty": { "type": "string" },
        "fees": { "type": "number" },
        "bio": { "type": "string" },
        "availability": { "type": "array" },
        "approved": { "type": "boolean" },
        "rating": { "type": "number" }
      },
      "required": ["id", "name", "email", "phone", "degree", "specialty", "fees", "bio", "availability", "approved", "rating"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Consultation record between a seeker and a doctor.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "specialty": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid"] },
        "meetingLink": { "type": "string" },
        "prescription": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "doctorId", "doctorName", "specialty", "date", "time", "status", "paymentStatus", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Remedies or Bookstore product purchase transaction record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "paymentId": { "type": "string" },
        "createdAt": { "type": "string" },
        "couponCode": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "items", "total", "status", "paymentId", "createdAt"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "Product saved by a user to their persistent wishlist.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "The target product ID" },
        "name": { "type": "string", "description": "The product name" },
        "price": { "type": "number", "description": "Product unit price" },
        "category": { "type": "string", "description": "Product category" },
        "imageUrl": { "type": "string", "description": "Product visual thumbnail" },
        "addedAt": { "type": "string", "description": "ISO timestamp of wishlist addition" }
      },
      "required": ["productId", "name", "price", "category", "imageUrl", "addedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Cosmic identity settings and user metadata."
    },
    "doctors/{doctorId}": {
      "schema": { "$ref": "#/entities/DoctorProfile" },
      "description": "Doctor profile registration and specialty definitions."
    },
    "appointments/{appointmentId}": {
      "schema": { "$ref": "#/entities/Appointment" },
      "description": "Scheduled appointments and consult notes."
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Completed payment cart records."
    },
    "users/{userId}/wishlist/{productId}": {
      "schema": { "$ref": "#/entities/WishlistItem" },
      "description": "Subcollection storing persistent wishlist products per user."
    }
  }
}
